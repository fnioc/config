#!/usr/bin/env sh
# Fast pre-commit gate. Runs moon's :lint task across affected packages.
# Skipped silently if moon isn't on PATH (e.g. a non-mise shell) so commits
# never hard-fail on a missing toolchain -- run
# `eval "$(mise activate bash)"` (or zsh) to bring it in.
#
# Also skipped (not failed) while the workspace defines zero lint tasks --
# true only during the monorepo scaffolding window before packages/*
# land their own moon.yml; `moon run :lint` itself errors with "No tasks
# found" in that state, which isn't a real lint failure.
set -e
if command -v moon >/dev/null 2>&1; then
  if moon query tasks 2>/dev/null | grep -q '"lint"'; then
    moon run :lint
  fi
fi
