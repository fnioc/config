{
  // Type-check-only superset of tsconfig.json, used by `npm run lint`.
  //
  // tsconfig.json's `include` is intentionally `src/**/*` only -- `npm run
  // build` must emit exclusively from `src/` into `dist/`. But that means
  // `tsc --noEmit` against the base config never type-checks `test/**/*`,
  // so compile-time-only assertions living in test files (e.g. the
  // `SchemaFor<T>` compile-fail fixtures in test/schema.test.ts, or the
  // "if this stopped being exported, this file would fail to type-check"
  // comment in test/index.test.ts) were never actually verified by any
  // command this repo runs. This config widens coverage to test/ without
  // touching what `npm run build` emits.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    // Base config restricts ambient @types inclusion to "node" only (so
    // `npm run build` never picks up bun's globals for src/). Test files
    // need "bun:test" (@types/bun) too.
    "types": ["node", "bun"]
  },
  "include": ["src/**/*", "test/**/*"]
}
