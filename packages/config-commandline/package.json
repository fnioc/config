{
  "name": "@fnconfig/commandline",
  "version": "0.0.0",
  "description": "Command-line configuration provider for @fnconfig/config: CommandLineConfigurationSource/Provider + the addCommandLine augmentation.",
  "keywords": [
    "configuration",
    "config",
    "command-line",
    "cli",
    "argv",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/config.git",
    "directory": "packages/config-commandline"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "moon run config-commandline:build",
    "test": "moon run config-commandline:test",
    "lint": "moon run config-commandline:lint"
  },
  "dependencies": {
    "@fnconfig/core": "workspace:*"
  },
  "peerDependencies": {
    "@fnconfig/config": "workspace:^"
  },
  "devDependencies": {
    "@fnconfig/config": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
