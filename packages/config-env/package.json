{
  "name": "@fnioc/config-env",
  "version": "0.0.0",
  "description": "process.env configuration provider for @fnioc/config: EnvironmentVariablesConfigurationSource/Provider + the addEnvironmentVariables augmentation.",
  "keywords": [
    "configuration",
    "config",
    "env",
    "environment-variables",
    "options",
    "ioc",
    "typescript",
    "dotnet"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/config.git",
    "directory": "packages/config-env"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "moon run config-env:build",
    "test": "moon run config-env:test",
    "lint": "moon run config-env:lint"
  },
  "peerDependencies": {
    "@fnioc/config": "workspace:^"
  },
  "devDependencies": {
    "@fnioc/config": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
